// Offisdesign domain model — Stage 4 implementation.
// See: docs/prisma-schema-design.md, docs/domain-model.md.
//
// Conventions enforced everywhere:
// - UUIDv7 primary keys (generated by app via uuidv7() — DB default omitted so
//   PKs are always assigned by app code to keep them time-ordered).
// - Money stored as minor units (Int) with a currency column on every money field.
// - Soft delete via deleted_at TIMESTAMPTZ (null = active).
// - Audit columns: created_at, updated_at (TIMESTAMPTZ).
// - Cross-context references are scalar foreign keys WITHOUT Prisma `@relation`
//   (id-only) per the locked architectural rule.
// - Append-only ledgers (StockAdjustment, OrderEvent) have no UPDATE/DELETE —
//   enforce in service layer; Prisma can't model that constraint.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, citext, pg_trgm]
}

// ──────────────────────────────────────────────────────────────────────────
// Identity & access — AdminUser context
// ──────────────────────────────────────────────────────────────────────────

model AdminUser {
  id           String    @id @db.Uuid
  email        String    @unique @db.Citext
  passwordHash String    @map("password_hash")
  displayName  String    @map("display_name")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz(6)
  /// Optimistic-locking counter; bump on every UPDATE and assert in WHERE.
  version      Int       @default(0)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  roles    AdminUserRole[]
  sessions AdminSession[]

  @@index([deletedAt])
  @@map("admin_user")
}

model Role {
  id          String   @id @db.Uuid
  key         String   @unique
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  permissions RolePermission[]
  users       AdminUserRole[]

  @@map("role")
}

model Permission {
  id          String   @id @db.Uuid
  key         String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  roles RolePermission[]

  @@map("permission")
}

model RolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permission")
}

model AdminUserRole {
  adminUserId String   @map("admin_user_id") @db.Uuid
  roleId      String   @map("role_id") @db.Uuid
  grantedAt   DateTime @default(now()) @map("granted_at") @db.Timestamptz(6)
  grantedBy   String?  @map("granted_by") @db.Uuid

  user AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  role Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([adminUserId, roleId])
  @@map("admin_user_role")
}

model AdminSession {
  id              String    @id @db.Uuid
  adminUserId     String    @map("admin_user_id") @db.Uuid
  refreshTokenJti String    @unique @map("refresh_token_jti")
  userAgent       String?   @map("user_agent")
  ipAddress       String?   @map("ip_address")
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt       DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@map("admin_session")
}

// ──────────────────────────────────────────────────────────────────────────
// Customer context (fully separate aggregate from AdminUser)
// ──────────────────────────────────────────────────────────────────────────

model Customer {
  id              String    @id @db.Uuid
  email           String    @unique @db.Citext
  passwordHash    String?   @map("password_hash")
  firstName       String?   @map("first_name")
  lastName        String?   @map("last_name")
  phone           String?
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz(6)
  marketingOptIn  Boolean   @default(false) @map("marketing_opt_in")
  lastLoginAt     DateTime? @map("last_login_at") @db.Timestamptz(6)
  version         Int       @default(0)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

  addresses CustomerAddress[]
  sessions  CustomerSession[]

  @@index([deletedAt])
  @@map("customer")
}

model CustomerAddress {
  id          String    @id @db.Uuid
  customerId  String    @map("customer_id") @db.Uuid
  label       String?
  firstName   String    @map("first_name")
  lastName    String    @map("last_name")
  line1       String
  line2       String?
  city        String
  region      String?
  postcode    String
  countryCode String    @map("country_code") @db.Char(2)
  phone       String?
  isDefault   Boolean   @default(false) @map("is_default")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_address")
}

model CustomerSession {
  id              String    @id @db.Uuid
  customerId      String    @map("customer_id") @db.Uuid
  refreshTokenJti String    @unique @map("refresh_token_jti")
  userAgent       String?   @map("user_agent")
  ipAddress       String?   @map("ip_address")
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt       DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_session")
}

// ──────────────────────────────────────────────────────────────────────────
// Catalogue
// ──────────────────────────────────────────────────────────────────────────

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED

  @@map("product_status")
}

model Product {
  id          String        @id @db.Uuid
  slug        String        @unique
  name        String
  description String?
  status      ProductStatus @default(DRAFT)
  brand       String?
  /// Optimistic concurrency token (incremented on every update).
  version     Int           @default(0)
  publishedAt DateTime?     @map("published_at") @db.Timestamptz(6)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?     @map("deleted_at") @db.Timestamptz(6)

  variants       ProductVariant[]
  options        ProductOption[]
  media          ProductMedia[]
  collections    ProductCollection[]
  categories     ProductCategory[]
  tags           ProductTag[]
  linksFrom      ProductLink[]          @relation("ProductLinkFrom")
  linksTo        ProductLink[]          @relation("ProductLinkTo")
  specifications ProductSpecification[]
  documents      ProductDocument[]

  @@index([status, publishedAt])
  @@index([deletedAt])
  @@map("product")
}

model ProductSpecification {
  id        String   @id @db.Uuid
  productId String   @map("product_id") @db.Uuid
  key       String
  label     String
  value     String
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, key])
  @@map("product_specification")
}

model ProductDocument {
  id        String   @id @db.Uuid
  productId String   @map("product_id") @db.Uuid
  mediaId   String   @map("media_id") @db.Uuid
  name      String
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, mediaId])
  @@map("product_document")
}

model ProductOption {
  id        String   @id @db.Uuid
  productId String   @map("product_id") @db.Uuid
  key       String
  name      String
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  product Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  values  ProductOptionValue[]

  @@unique([productId, key])
  @@map("product_option")
}

model ProductOptionValue {
  id        String   @id @db.Uuid
  optionId  String   @map("option_id") @db.Uuid
  value     String
  label     String
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  option   ProductOption          @relation(fields: [optionId], references: [id], onDelete: Cascade)
  variants ProductVariantOption[]

  @@unique([optionId, value])
  @@map("product_option_value")
}

model ProductVariant {
  id              String    @id @db.Uuid
  productId       String    @map("product_id") @db.Uuid
  sku             String    @unique
  barcode         String?
  name            String?
  priceAmount     Int       @map("price_amount")
  priceCurrency   String    @default("NGN") @map("price_currency") @db.Char(3)
  compareAtAmount Int?      @map("compare_at_amount")
  weightGrams     Int?      @map("weight_grams")
  isDefault       Boolean   @default(false) @map("is_default")
  version         Int       @default(0)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

  product Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  options ProductVariantOption[]

  @@index([productId])
  @@index([deletedAt])
  @@map("product_variant")
}

model ProductVariantOption {
  variantId     String @map("variant_id") @db.Uuid
  optionValueId String @map("option_value_id") @db.Uuid

  variant     ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionValue ProductOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@id([variantId, optionValueId])
  @@map("product_variant_option")
}

model ProductMedia {
  id        String   @id @db.Uuid
  productId String   @map("product_id") @db.Uuid
  mediaId   String   @map("media_id") @db.Uuid
  alt       String?
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, mediaId])
  @@map("product_media")
}

model Collection {
  id          String    @id @db.Uuid
  slug        String    @unique
  name        String
  description String?
  isVisible   Boolean   @default(true) @map("is_visible")
  position    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  products ProductCollection[]

  @@map("collection")
}

model ProductCollection {
  productId    String @map("product_id") @db.Uuid
  collectionId String @map("collection_id") @db.Uuid
  position     Int    @default(0)

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
  @@map("product_collection")
}

model Category {
  id        String    @id @db.Uuid
  parentId  String?   @map("parent_id") @db.Uuid
  slug      String    @unique
  name      String
  position  Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  parent   Category?         @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[]        @relation("CategoryTree")
  products ProductCategory[]

  @@index([parentId])
  @@map("category")
}

model ProductCategory {
  productId  String @map("product_id") @db.Uuid
  categoryId String @map("category_id") @db.Uuid

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@map("product_category")
}

model Tag {
  id   String @id @db.Uuid
  slug String @unique
  name String

  products ProductTag[]

  @@map("tag")
}

model ProductTag {
  productId String @map("product_id") @db.Uuid
  tagId     String @map("tag_id") @db.Uuid

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@map("product_tag")
}

enum ProductLinkKind {
  RELATED
  CROSS_SELL
  UP_SELL

  @@map("product_link_kind")
}

model ProductLink {
  id            String          @id @db.Uuid
  fromProductId String          @map("from_product_id") @db.Uuid
  toProductId   String          @map("to_product_id") @db.Uuid
  kind          ProductLinkKind
  position      Int             @default(0)

  from Product @relation("ProductLinkFrom", fields: [fromProductId], references: [id], onDelete: Cascade)
  to   Product @relation("ProductLinkTo", fields: [toProductId], references: [id], onDelete: Cascade)

  @@unique([fromProductId, toProductId, kind])
  @@map("product_link")
}

// ──────────────────────────────────────────────────────────────────────────
// Inventory context
// ──────────────────────────────────────────────────────────────────────────

model Warehouse {
  id          String   @id @db.Uuid
  code        String   @unique
  name        String
  countryCode String   @map("country_code") @db.Char(2)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  items InventoryItem[]

  @@map("warehouse")
}

model InventoryItem {
  id          String   @id @db.Uuid
  variantId   String   @map("variant_id") @db.Uuid
  warehouseId String   @map("warehouse_id") @db.Uuid
  onHand      Int      @default(0) @map("on_hand")
  reserved    Int      @default(0)
  reorderAt   Int?     @map("reorder_at")
  /// Optimistic concurrency token. Increment on every mutation; assert prior
  /// version in the WHERE clause to detect concurrent writers.
  version     Int      @default(0)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  warehouse    Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  reservations StockReservation[]
  adjustments  StockAdjustment[]

  @@unique([variantId, warehouseId])
  @@index([warehouseId])
  @@map("inventory_item")
}

enum StockReservationStatus {
  HELD
  CONSUMED
  RELEASED
  EXPIRED

  @@map("stock_reservation_status")
}

model StockReservation {
  id              String                 @id @db.Uuid
  inventoryItemId String                 @map("inventory_item_id") @db.Uuid
  contextType     String                 @map("context_type")
  contextId       String                 @map("context_id") @db.Uuid
  quantity        Int
  status          StockReservationStatus @default(HELD)
  expiresAt       DateTime?              @map("expires_at") @db.Timestamptz(6)
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  item InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([contextType, contextId])
  @@index([status, expiresAt])
  @@map("stock_reservation")
}

enum StockAdjustmentReason {
  PURCHASE
  SALE
  RETURN
  COUNT
  DAMAGE
  TRANSFER

  @@map("stock_adjustment_reason")
}

/// Append-only ledger. Service layer must enforce no UPDATE / DELETE.
model StockAdjustment {
  id              String                @id @db.Uuid
  inventoryItemId String                @map("inventory_item_id") @db.Uuid
  delta           Int
  reason          StockAdjustmentReason
  reference       String?
  actorId         String?               @map("actor_id") @db.Uuid
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  item InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([inventoryItemId, createdAt])
  @@map("stock_adjustment")
}

// ──────────────────────────────────────────────────────────────────────────
// Cart context — guest + authenticated, merged on sign-in
// ──────────────────────────────────────────────────────────────────────────

enum CartStatus {
  ACTIVE
  CHECKED_OUT
  ABANDONED

  @@map("cart_status")
}

model Cart {
  id            String     @id @db.Uuid
  customerId    String?    @map("customer_id") @db.Uuid
  anonymousId   String?    @map("anonymous_id") @db.Uuid
  email         String?    @db.Citext
  currency      String     @default("NGN") @db.Char(3)
  status        CartStatus @default(ACTIVE)
  appliedCoupon String?    @map("applied_coupon")
  /// Optimistic concurrency.
  version       Int        @default(0)
  expiresAt     DateTime?  @map("expires_at") @db.Timestamptz(6)
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  items CartItem[]

  @@index([customerId])
  @@index([anonymousId])
  @@index([status])
  @@map("cart")
}

model CartItem {
  id         String   @id @db.Uuid
  cartId     String   @map("cart_id") @db.Uuid
  variantId  String   @map("variant_id") @db.Uuid
  quantity   Int
  unitAmount Int      @map("unit_amount")
  currency   String   @default("NGN") @db.Char(3)
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId])
  @@map("cart_item")
}

// ──────────────────────────────────────────────────────────────────────────
// Order & Payment
// ──────────────────────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  PAID
  FULFILLING
  SHIPPED
  COMPLETED
  CANCELLED
  REFUNDED

  @@map("order_status")
}

model Order {
  id              String      @id @db.Uuid
  number          String      @unique
  customerId      String?     @map("customer_id") @db.Uuid
  email           String      @db.Citext
  currency        String      @default("NGN") @db.Char(3)
  subtotalAmount  Int         @map("subtotal_amount")
  shippingAmount  Int         @map("shipping_amount")
  taxAmount       Int         @map("tax_amount")
  discountAmount  Int         @default(0) @map("discount_amount")
  totalAmount     Int         @map("total_amount")
  status          OrderStatus @default(PENDING)
  placedAt        DateTime?   @map("placed_at") @db.Timestamptz(6)
  shippingAddress Json        @map("shipping_address")
  billingAddress  Json?       @map("billing_address")
  version         Int         @default(0)
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?   @map("deleted_at") @db.Timestamptz(6)

  items    OrderItem[]
  payments Payment[]
  events   OrderEvent[]

  @@index([customerId])
  @@index([status, placedAt])
  @@map("order")
}

model OrderItem {
  id          String   @id @db.Uuid
  orderId     String   @map("order_id") @db.Uuid
  variantId   String   @map("variant_id") @db.Uuid
  productName String   @map("product_name")
  variantName String?  @map("variant_name")
  sku         String
  quantity    Int
  unitAmount  Int      @map("unit_amount")
  totalAmount Int      @map("total_amount")
  currency    String   @default("NGN") @db.Char(3)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_item")
}

/// Append-only event log for orders.
model OrderEvent {
  id        String   @id @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  kind      String
  payload   Json
  actorId   String?  @map("actor_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@map("order_event")
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED

  @@map("payment_status")
}

/// Provider-agnostic. `providerData` is the source of truth for provider-specific
/// state (Stripe paymentIntent, etc). Stripe is one of many possible providers.
model Payment {
  id           String        @id @db.Uuid
  orderId      String        @map("order_id") @db.Uuid
  provider     String
  providerRef  String        @map("provider_ref")
  amount       Int
  currency     String        @default("NGN") @db.Char(3)
  status       PaymentStatus @default(PENDING)
  providerData Json          @map("provider_data")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([provider, providerRef])
  @@index([orderId])
  @@map("payment")
}

// ──────────────────────────────────────────────────────────────────────────
// CMS context
// ──────────────────────────────────────────────────────────────────────────

enum CmsStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED

  @@map("cms_status")
}

enum CmsPageKind {
  STANDARD
  LANDING

  @@map("cms_page_kind")
}

model CmsPage {
  id          String      @id @db.Uuid
  slug        String      @unique
  title       String
  kind        CmsPageKind @default(STANDARD)
  status      CmsStatus   @default(DRAFT)
  seo         Json?
  publishedAt DateTime?   @map("published_at") @db.Timestamptz(6)
  scheduledAt DateTime?   @map("scheduled_at") @db.Timestamptz(6)
  unscheduledAt DateTime? @map("unscheduled_at") @db.Timestamptz(6)
  version     Int         @default(0)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?   @map("deleted_at") @db.Timestamptz(6)

  blocks CmsBlock[]

  @@index([status, scheduledAt])
  @@index([status, unscheduledAt])
  @@map("cms_page")
}

model CmsBlock {
  id        String   @id @db.Uuid
  pageId    String   @map("page_id") @db.Uuid
  kind      String
  position  Int      @default(0)
  payload   Json
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  page CmsPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, position])
  @@map("cms_block")
}

model Navigation {
  id        String   @id @db.Uuid
  key       String   @unique
  name      String
  items     Json
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("navigation")
}

model Faq {
  id        String   @id @db.Uuid
  category  String?
  question  String
  answer    String
  position  Int      @default(0)
  isVisible Boolean  @default(true) @map("is_visible")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("faq")
}

model Testimonial {
  id        String   @id @db.Uuid
  author    String
  quote     String
  source    String?
  imageId   String?  @map("image_id") @db.Uuid
  isVisible Boolean  @default(true) @map("is_visible")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("testimonial")
}

model Announcement {
  id        String    @id @db.Uuid
  message   String
  href      String?
  startsAt  DateTime? @map("starts_at") @db.Timestamptz(6)
  endsAt    DateTime? @map("ends_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("announcement")
}

model MediaFolder {
  id        String   @id @db.Uuid
  parentId  String?  @map("parent_id") @db.Uuid
  name      String
  path      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  parent   MediaFolder?  @relation("MediaFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children MediaFolder[] @relation("MediaFolderTree")
  items    Media[]

  @@index([parentId])
  @@map("media_folder")
}

model Media {
  id          String   @id @db.Uuid
  folderId    String?  @map("folder_id") @db.Uuid
  storageKey  String   @unique @map("storage_key")
  filename    String?
  contentType String   @map("content_type")
  byteSize    Int      @map("byte_size")
  width       Int?
  height      Int?
  alt         String?
  /// Focal point as fractions (0–1), used to crop responsive renditions.
  focalX      Float?   @map("focal_x")
  focalY      Float?   @map("focal_y")
  /// Map of {label → { key, width, height, contentType }} for derivatives
  /// produced by the image-processing worker.
  derivatives Json?
  uploadedBy  String?  @map("uploaded_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  folder MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([folderId])
  @@index([deletedAt])
  @@map("media")
}

// ──────────────────────────────────────────────────────────────────────────
// Events & webhooks
// ──────────────────────────────────────────────────────────────────────────

model DomainEvent {
  id            String   @id @db.Uuid
  type          String
  aggregateType String   @map("aggregate_type")
  aggregateId   String   @map("aggregate_id") @db.Uuid
  payload       Json
  occurredAt    DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)

  @@index([aggregateType, aggregateId])
  @@index([type, occurredAt])
  @@map("domain_event")
}

model Webhook {
  id        String   @id @db.Uuid
  url       String
  secret    String
  events    String[]
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  deliveries WebhookDelivery[]

  @@map("webhook")
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED

  @@map("webhook_delivery_status")
}

model WebhookDelivery {
  id            String                @id @db.Uuid
  webhookId     String                @map("webhook_id") @db.Uuid
  eventId       String                @map("event_id") @db.Uuid
  status        WebhookDeliveryStatus @default(PENDING)
  attempts      Int                   @default(0)
  lastError     String?               @map("last_error")
  nextAttemptAt DateTime?             @map("next_attempt_at") @db.Timestamptz(6)
  deliveredAt   DateTime?             @map("delivered_at") @db.Timestamptz(6)
  /// Hash of (webhookId, eventId, payload). Prevents duplicate dispatch on retry.
  idempotencyKey String?              @unique @map("idempotency_key")
  createdAt     DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, status])
  @@map("webhook_delivery")
}

// ──────────────────────────────────────────────────────────────────────────
// Pricing — discounts, coupons, promotions
// ──────────────────────────────────────────────────────────────────────────

enum DiscountKind {
  PERCENT
  FIXED

  @@map("discount_kind")
}

enum DiscountScope {
  CART
  PRODUCT
  COLLECTION

  @@map("discount_scope")
}

model Discount {
  id          String        @id @db.Uuid
  /// Public coupon code. `null` means an automatic promotion (no code entry).
  code        String?       @unique
  name        String
  kind        DiscountKind
  /// Percent: 0–10000 representing 0.00–100.00%. Fixed: minor units.
  value       Int
  currency    String?       @db.Char(3)
  scope       DiscountScope @default(CART)
  /// Optional filter ids for PRODUCT/COLLECTION scope.
  targetIds   String[]      @map("target_ids") @db.Uuid
  minSubtotal Int?          @map("min_subtotal")
  startsAt    DateTime?     @map("starts_at") @db.Timestamptz(6)
  endsAt      DateTime?     @map("ends_at") @db.Timestamptz(6)
  usageLimit  Int?          @map("usage_limit")
  usageCount  Int           @default(0) @map("usage_count")
  isActive    Boolean       @default(true) @map("is_active")
  version     Int           @default(0)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?     @map("deleted_at") @db.Timestamptz(6)

  usages DiscountUsage[]

  @@index([code])
  @@index([isActive, startsAt, endsAt])
  @@map("discount")
}

model DiscountUsage {
  id         String   @id @db.Uuid
  discountId String   @map("discount_id") @db.Uuid
  /// Order, cart, or any context that consumed this discount.
  contextType String  @map("context_type")
  contextId  String   @map("context_id") @db.Uuid
  amount     Int
  currency   String   @default("NGN") @db.Char(3)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  discount Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)

  @@index([discountId, createdAt])
  @@map("discount_usage")
}

// ──────────────────────────────────────────────────────────────────────────
// Customer identity — verification + reset tokens
// ──────────────────────────────────────────────────────────────────────────

enum VerificationTokenKind {
  EMAIL_VERIFICATION
  PASSWORD_RESET

  @@map("verification_token_kind")
}

model VerificationToken {
  id         String                @id @db.Uuid
  customerId String                @map("customer_id") @db.Uuid
  kind       VerificationTokenKind
  /// Hex SHA-256 of the raw token. The raw token is delivered out-of-band
  /// (email link) and never stored.
  tokenHash  String                @unique @map("token_hash")
  expiresAt  DateTime              @map("expires_at") @db.Timestamptz(6)
  usedAt     DateTime?             @map("used_at") @db.Timestamptz(6)
  createdAt  DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([customerId, kind])
  @@map("verification_token")
}

// ──────────────────────────────────────────────────────────────────────────
// Checkout session state machine
// ──────────────────────────────────────────────────────────────────────────

enum CheckoutStatus {
  PENDING
  AWAITING_PAYMENT
  COMPLETED
  EXPIRED
  CANCELLED

  @@map("checkout_status")
}

model CheckoutSession {
  id              String         @id @db.Uuid
  cartId          String         @unique @map("cart_id") @db.Uuid
  customerId      String?        @map("customer_id") @db.Uuid
  email           String         @db.Citext
  currency        String         @default("NGN") @db.Char(3)
  shippingAddress Json?          @map("shipping_address")
  billingAddress  Json?          @map("billing_address")
  shippingMethod  Json?          @map("shipping_method")
  subtotalAmount  Int            @default(0) @map("subtotal_amount")
  shippingAmount  Int            @default(0) @map("shipping_amount")
  taxAmount       Int            @default(0) @map("tax_amount")
  discountAmount  Int            @default(0) @map("discount_amount")
  totalAmount     Int            @default(0) @map("total_amount")
  status          CheckoutStatus @default(PENDING)
  paymentProvider String?        @map("payment_provider")
  paymentIntentRef String?       @map("payment_intent_ref")
  reservationIds  String[]       @map("reservation_ids") @db.Uuid
  orderId         String?        @unique @map("order_id") @db.Uuid
  expiresAt       DateTime       @map("expires_at") @db.Timestamptz(6)
  /// Optimistic concurrency.
  version         Int            @default(0)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([customerId])
  @@index([status, expiresAt])
  @@map("checkout_session")
}

// ──────────────────────────────────────────────────────────────────────────
// Idempotency keys — order placement + any other write-once endpoint
// ──────────────────────────────────────────────────────────────────────────

model IdempotencyKey {
  /// Caller-supplied idempotency key, scoped by route+principal.
  key         String   @id
  /// Hash of the request body so we can detect a replay vs a different
  /// request reusing the same key.
  requestHash String   @map("request_hash")
  /// Stored JSON of the original response so retries return the same body.
  response    Json
  statusCode  Int      @map("status_code")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt   DateTime @map("expires_at") @db.Timestamptz(6)

  @@index([expiresAt])
  @@map("idempotency_key")
}

// ──────────────────────────────────────────────────────────────────────────
// CMS — blog
// ──────────────────────────────────────────────────────────────────────────

model Author {
  id        String   @id @db.Uuid
  slug      String   @unique
  name      String
  bio       String?
  avatarMediaId String? @map("avatar_media_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  posts BlogPost[]

  @@map("author")
}

model BlogPost {
  id            String    @id @db.Uuid
  slug          String    @unique
  title         String
  excerpt       String?
  body          String
  coverMediaId  String?   @map("cover_media_id") @db.Uuid
  authorId      String?   @map("author_id") @db.Uuid
  status        CmsStatus @default(DRAFT)
  seo           Json?
  publishedAt   DateTime? @map("published_at") @db.Timestamptz(6)
  scheduledAt   DateTime? @map("scheduled_at") @db.Timestamptz(6)
  unscheduledAt DateTime? @map("unscheduled_at") @db.Timestamptz(6)
  tags          String[]
  version       Int       @default(0)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)

  author Author? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([status, publishedAt])
  @@index([status, scheduledAt])
  @@index([authorId])
  @@map("blog_post")
}

// ──────────────────────────────────────────────────────────────────────────
// Audit + revisions
// ──────────────────────────────────────────────────────────────────────────

model ContentRevision {
  id            String   @id @db.Uuid
  aggregateType String   @map("aggregate_type")
  aggregateId   String   @map("aggregate_id") @db.Uuid
  /// Sequential revision number per (aggregateType, aggregateId).
  version       Int
  /// Snapshot of the row at this revision.
  snapshot      Json
  /// Optional diff against the previous revision (for fast UI display).
  diff          Json?
  actorId       String?  @map("actor_id") @db.Uuid
  reason        String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([aggregateType, aggregateId, version])
  @@index([aggregateType, aggregateId])
  @@map("content_revision")
}

model AdminActivityLog {
  id          String   @id @db.Uuid
  actorId     String?  @map("actor_id") @db.Uuid
  action      String
  aggregateType String? @map("aggregate_type")
  aggregateId String?  @map("aggregate_id") @db.Uuid
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([actorId, createdAt])
  @@index([aggregateType, aggregateId])
  @@index([createdAt])
  @@map("admin_activity_log")
}

// ──────────────────────────────────────────────────────────────────────────
// Operational — feature flags, settings, maintenance
// ──────────────────────────────────────────────────────────────────────────

model FeatureFlag {
  id          String   @id @db.Uuid
  key         String   @unique
  name        String
  description String?
  /// On/off master switch.
  enabled     Boolean  @default(false)
  /// Percent (0-100) rollout for gradual exposure.
  rolloutPct  Int      @default(0) @map("rollout_pct")
  /// Optional JSON payload for additional config (variants, allowlists).
  config      Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("feature_flag")
}

model SystemSetting {
  /// Stable key — namespaced (`commerce.*`, `seo.*`, `support.*`).
  key       String   @id
  value     Json
  /// Whether this setting may be read by unauthenticated storefront callers.
  isPublic  Boolean  @default(false) @map("is_public")
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("system_setting")
}

// ──────────────────────────────────────────────────────────────────────────
// Notification engine
// ──────────────────────────────────────────────────────────────────────────

enum NotificationChannel {
  EMAIL
  SMS
  PUSH

  @@map("notification_channel")
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELLED

  @@map("notification_status")
}

model NotificationTemplate {
  id        String              @id @db.Uuid
  key       String              @unique
  channel   NotificationChannel
  subject   String?
  body      String
  metadata  Json?
  isActive  Boolean             @default(true) @map("is_active")
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("notification_template")
}

model NotificationDelivery {
  id          String              @id @db.Uuid
  templateKey String              @map("template_key")
  channel     NotificationChannel
  /// E.g. an email address or phone number.
  recipient   String
  payload     Json
  status      NotificationStatus  @default(PENDING)
  providerId  String?             @map("provider_id")
  error       String?
  attempts    Int                 @default(0)
  /// Hash of (templateKey, recipient, payload). Prevents duplicate sends on retry.
  idempotencyKey String?          @unique @map("idempotency_key")
  sentAt      DateTime?           @map("sent_at") @db.Timestamptz(6)
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status, createdAt])
  @@index([templateKey])
  @@map("notification_delivery")
}

// ──────────────────────────────────────────────────────────────────────────
// Marketing
// ──────────────────────────────────────────────────────────────────────────

model NewsletterSubscription {
  id           String    @id @db.Uuid
  email        String    @unique @db.Citext
  source       String?
  /// Optional referrer URL captured at signup.
  referrer     String?
  consentedAt  DateTime  @default(now()) @map("consented_at") @db.Timestamptz(6)
  unsubscribedAt DateTime? @map("unsubscribed_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([unsubscribedAt])
  @@map("newsletter_subscription")
}

// ──────────────────────────────────────────────────────────────────────────
// Reviews + wishlist (Stage 11)
// ──────────────────────────────────────────────────────────────────────────

enum ReviewStatus {
  PENDING
  PUBLISHED
  REJECTED

  @@map("review_status")
}

model ProductReview {
  id               String       @id @db.Uuid
  productId        String       @map("product_id") @db.Uuid
  customerId       String?      @map("customer_id") @db.Uuid
  /// Rating 1–5.
  rating           Int
  title            String?
  body             String
  /// Set when the reviewer has an order containing this product.
  verifiedPurchase Boolean      @default(false) @map("verified_purchase")
  status           ReviewStatus @default(PENDING)
  helpfulCount     Int          @default(0) @map("helpful_count")
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?    @map("deleted_at") @db.Timestamptz(6)

  votes ReviewHelpfulVote[]

  @@index([productId, status, createdAt])
  @@index([customerId])
  @@map("product_review")
}

model ReviewHelpfulVote {
  reviewId   String   @map("review_id") @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  review ProductReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@id([reviewId, customerId])
  @@map("review_helpful_vote")
}

model WishlistItem {
  customerId String   @map("customer_id") @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  addedAt    DateTime @default(now()) @map("added_at") @db.Timestamptz(6)

  @@id([customerId, productId])
  @@index([customerId, addedAt])
  @@map("wishlist_item")
}
