# Production environment template.
#
# Copy this file into your secrets manager (Doppler / 1Password / SSM / k8s
# secrets / Coolify env panel — whichever your platform uses). DO NOT commit
# a populated copy. Every secret here is validated at boot by
# `loadApiEnv()` (packages/config/src/env.ts); a missing or under-length
# value aborts the process before it accepts traffic.

# ── Runtime ──────────────────────────────────────────────────────────────
NODE_ENV=production
APP_ENV=production
LOG_LEVEL=info

# ── API server ───────────────────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
API_PUBLIC_URL=https://api.offisdesign.com
WEB_PUBLIC_URL=https://offisdesign.com
ADMIN_PUBLIC_URL=https://admin.offisdesign.com

# ── Database ─────────────────────────────────────────────────────────────
# Use a managed Postgres (Neon, Supabase, RDS, Cloud SQL). Enable SSL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/offisdesign?schema=public&sslmode=require
DATABASE_POOL_MAX=20

# ── Redis ────────────────────────────────────────────────────────────────
# Managed Redis with TLS in production.
REDIS_URL=rediss://default:PASSWORD@HOST:6380

# ── Auth ─────────────────────────────────────────────────────────────────
# Generate fresh 48-byte secrets: `openssl rand -base64 48`
JWT_ACCESS_SECRET=REPLACE_WITH_48_BYTE_SECRET
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_SECRET=REPLACE_WITH_48_BYTE_SECRET
JWT_REFRESH_TTL_SEC=2592000

COOKIE_DOMAIN=.offisdesign.com
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
BCRYPT_ROUNDS=12

# ── Rate limit ───────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=240
RATE_LIMIT_AUTH=10

# ── Storage (S3-compatible) ──────────────────────────────────────────────
STORAGE_DRIVER=s3
S3_BUCKET=offisdesign-prod
S3_REGION=eu-west-2
S3_ENDPOINT=https://s3.eu-west-2.amazonaws.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
STORAGE_PUBLIC_BASE_URL=https://cdn.offisdesign.com

# ── BullMQ ───────────────────────────────────────────────────────────────
QUEUE_PREFIX=offis-prod
QUEUE_DEFAULT_ATTEMPTS=5

# ── OpenAPI ──────────────────────────────────────────────────────────────
# Hide the swagger UI in production. Enable in staging if needed.
OPENAPI_ENABLED=false

# ── Payments (Stripe) ────────────────────────────────────────────────────
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_live_REPLACE
STRIPE_WEBHOOK_SECRET=whsec_REPLACE
STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE

# ── Email (SMTP) ─────────────────────────────────────────────────────────
EMAIL_TRANSPORT=smtp
EMAIL_FROM="Offisdesign <hello@offisdesign.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Tax / shipping ───────────────────────────────────────────────────────
TAX_PROVIDER=flat
TAX_FLAT_RATE_BPS=2000
SHIPPING_PROVIDER=flat
SHIPPING_FLAT_AMOUNT=999

# ── Cart / checkout ──────────────────────────────────────────────────────
CART_TTL_DAYS=30
CHECKOUT_TTL_MIN=60
CART_ABANDON_AFTER_HOURS=24

# ── Seed (optional, one-off) ─────────────────────────────────────────────
# Set once, run the seed, then remove from the production environment.
SEED_SUPER_ADMIN_EMAIL=
SEED_SUPER_ADMIN_PASSWORD=
