{
  "//": "webhint config consumed by the Microsoft Edge Tools (vscode-edge-devtools) editor integration. These hints run a STATIC axe/webhint pass over individual .tsx source files. Because they never render the components, they cannot evaluate dynamic ARIA values (e.g. aria-busy={loading || undefined}) or cross-component composition (FormField+Select, Stack as=\"ul\", Tabs children), so the axe/* and no-inline-styles rules produce false positives against correct code. Real accessibility is validated against the rendered DOM in tests, not here. compat-api/css is disabled because the -webkit-* prefixes in style.css are intentional cross-browser fallbacks.",
  "hints": {
    "axe/aria": "off",
    "axe/forms": "off",
    "axe/structure": "off",
    "axe/text-alternatives": "off",
    "axe/name-role-value": "off",
    "no-inline-styles": "off",
    "compat-api/css": "off"
  }
}
