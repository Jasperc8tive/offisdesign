{
  "name": "offisdesign",
  "private": true,
  "version": "1.0.0-rc.1",
  "description": "Shopify-free rebuild of branchfurniture.com — monorepo root",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.19",
    "pnpm": ">=9 <11"
  },
  "pnpm": {
    "overrides": {
      "multer@<2.2.0": "^2.2.0",
      "lodash@<4.18.0": "^4.18.0"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml,css}\"",
    "storybook": "pnpm --filter @offisdesign/ui storybook",
    "storybook:build": "pnpm --filter @offisdesign/ui storybook:build",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.15.0",
    "@types/node": "^20.17.6",
    "eslint": "^9.15.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "wait-on": "^9.0.10"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
