# Copy to .env for local development. NEVER commit a real .env.

NODE_ENV=development
APP_ENV=local
LOG_LEVEL=info

# API server
API_PORT=4000
API_HOST=0.0.0.0
API_PUBLIC_URL=http://localhost:4000
WEB_PUBLIC_URL=http://localhost:3000
ADMIN_PUBLIC_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://offis:offis@localhost:5432/offisdesign?schema=public
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379

# Auth — JWT (generate fresh: `openssl rand -base64 48`)
JWT_ACCESS_SECRET=change-me-change-me-change-me-change-me-change-me-32-chars-min
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_SECRET=change-me-change-me-change-me-change-me-change-me-32-chars-min
JWT_REFRESH_TTL_SEC=2592000

# Auth — cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

BCRYPT_ROUNDS=12

# Rate limit
RATE_LIMIT_DEFAULT=120
RATE_LIMIT_AUTH=10

# Storage
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./.storage
STORAGE_PUBLIC_BASE_URL=http://localhost:4000/media
# For S3 / S3-compatible:
# STORAGE_DRIVER=s3
# S3_BUCKET=offisdesign-dev
# S3_REGION=eu-west-2
# S3_ENDPOINT=https://s3.eu-west-2.amazonaws.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=false

# BullMQ
QUEUE_PREFIX=offis
QUEUE_DEFAULT_ATTEMPTS=5

# OpenAPI
OPENAPI_ENABLED=true

# Seed
SEED_SUPER_ADMIN_EMAIL=admin@offisdesign.local
SEED_SUPER_ADMIN_PASSWORD=change-me-immediately
